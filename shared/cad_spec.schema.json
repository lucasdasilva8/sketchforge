{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://sketchforge.dev/cad_spec.schema.json",
  "title": "CADSpec",
  "description": "Parametric CAD command sequence for sketch-to-CAD pipeline",
  "type": "object",
  "required": ["version", "units", "template", "sketches", "operations", "parameters"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "units": { "type": "string", "enum": ["mm", "cm", "in"] },
    "template": {
      "type": "string",
      "enum": ["box", "cylinder", "profile_extrude", "bracket"]
    },
    "sketches": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "plane", "profile"],
        "properties": {
          "id": { "type": "string" },
          "plane": { "type": "string", "enum": ["XY", "XZ", "YZ"] },
          "profile": {
            "type": "array",
            "items": {
              "type": "array",
              "items": { "type": "number" },
              "minItems": 2,
              "maxItems": 2
            },
            "minItems": 3
          }
        }
      }
    },
    "operations": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "required": ["op", "sketch", "distance"],
            "properties": {
              "op": { "const": "extrude" },
              "sketch": { "type": "string" },
              "distance": { "type": "number", "minimum": 0.1 }
            }
          },
          {
            "type": "object",
            "required": ["op", "radius"],
            "properties": {
              "op": { "const": "fillet" },
              "edges": { "type": "array", "items": { "type": "string" } },
              "radius": { "type": "number", "minimum": 0 }
            }
          },
          {
            "type": "object",
            "required": ["op", "sketch", "angle"],
            "properties": {
              "op": { "const": "revolve" },
              "sketch": { "type": "string" },
              "angle": { "type": "number", "minimum": 0, "maximum": 360 }
            }
          }
        ]
      }
    },
    "parameters": {
      "type": "object",
      "properties": {
        "width": { "type": "number", "minimum": 0.1 },
        "depth": { "type": "number", "minimum": 0.1 },
        "height": { "type": "number", "minimum": 0.1 },
        "radius": { "type": "number", "minimum": 0.1 },
        "fillet_radius": { "type": "number", "minimum": 0 },
        "wall_thickness": { "type": "number", "minimum": 0.1 },
        "leg_width": { "type": "number", "minimum": 0.1 }
      },
      "additionalProperties": true
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "source": { "type": "string", "enum": ["heuristic", "ml", "feedback", "manual"] }
  }
}
